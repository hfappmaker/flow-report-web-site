---
const included = [
  "作業報告書・請求書の生成（無制限）",
  "精算幅計算（上下割・中間割・控除/超過単価）",
  "作業報告の一括入力",
  "Excelテンプレートのカスタマイズ",
  "メールテンプレート機能",
  "パソコン・スマホ対応",
];
---

<section id="pricing" class="relative py-24 sm:py-32">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Pricing</span>
      <h2 class="mt-5 text-4xl font-semibold tracking-tight text-ink-900 sm:text-5xl">
        <span class="gradient-text">完全無料</span>で<br class="hidden sm:block" />
        ご利用いただけます。
      </h2>
      <p class="mt-4 text-lg text-ink-600">
        課金プランも、トライアル期限もありません。Googleアカウントがあれば、そのまま使い始められます。
      </p>
    </div>

    <div class="mx-auto mt-14 max-w-xl">
      <div class="card relative flex flex-col border-brand-300 ring-2 ring-brand-200">
        <span class="absolute -top-3 left-6 rounded-full bg-gradient-to-r from-brand-500 to-mint-500 px-3 py-1 text-[11px] font-semibold text-white shadow-md">
          すべての機能を無料で
        </span>
        <div class="text-sm font-semibold tracking-wide text-ink-700">Flow Report</div>
        <div class="mt-3 flex items-baseline gap-1.5">
          <span class="text-5xl font-bold tracking-tight text-ink-900">¥0</span>
          <span class="text-sm text-ink-500">/ ずっと無料</span>
        </div>
        <div class="mt-1 text-xs text-ink-500">フリーランスエンジニアのための作業報告書・請求書作成システム</div>

        <ul class="mt-6 space-y-2.5 text-sm text-ink-700">
          {
            included.map((f) => (
              <li class="flex gap-2">
                <svg viewBox="0 0 20 20" width="18" height="18" class="mt-0.5 flex-none text-mint-500" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10l4 4 8-8" /></svg>
                <span>{f}</span>
              </li>
            ))
          }
        </ul>

        <a
          href="https://www.flowreport.app"
          target="_blank"
          rel="noopener"
          class="btn-primary mt-8 justify-center"
        >
          ログイン画面へ
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>

    <p class="mt-8 text-center text-xs text-ink-500">
      ※ご利用にはGoogleアカウントが必要になります。
    </p>
  </div>
</section>
